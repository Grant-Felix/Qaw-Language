// 文件名: four-form.yao
// 演示四形制关键字（任意一种写法都被识别）

package four_form

baozhuang four_form    // 等价于 package four_form

// 英文原形
func english() -> void {
    print("english")
}

// 英文缩写
fn abbrev() -> void {
    print("abbrev")
}

// 汉语全拼
hanshu pinyin_full() -> void {
    print("pinyin_full")
}

// 拼音首字母
hs pinyin_init() -> void {
    print("pinyin_init")
}

func main() -> void {
    english()
    abbrev()
    pinyin_full()
    pinyin_init()
}
